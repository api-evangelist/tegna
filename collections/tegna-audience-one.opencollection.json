{
  "opencollection": "1.0.0",
  "info": {
    "name": "TEGNA AudienceOne API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Audiences",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Audiences",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.tegna.com/v1/audiences",
            "params": [
              {
                "name": "market",
                "value": "",
                "type": "query",
                "description": "Filter audiences by TEGNA market (DMA code or city name)."
              },
              {
                "name": "type",
                "value": "",
                "type": "query",
                "description": "Filter by audience segment type."
              },
              {
                "name": "page",
                "value": "",
                "type": "query"
              },
              {
                "name": "pageSize",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve available audience segments for targeting in TEGNA campaigns."
        },
        {
          "info": {
            "name": "Get Audience",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.tegna.com/v1/audiences/:audienceId",
            "params": [
              {
                "name": "audienceId",
                "value": "",
                "type": "path"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve details about a specific audience segment."
        }
      ]
    },
    {
      "info": {
        "name": "Campaigns",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Campaigns",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.tegna.com/v1/campaigns",
            "params": [
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Filter campaigns by status."
              },
              {
                "name": "page",
                "value": "",
                "type": "query"
              },
              {
                "name": "pageSize",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve advertising campaigns for the authenticated advertiser."
        },
        {
          "info": {
            "name": "Create Campaign",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.tegna.com/v1/campaigns",
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Create a new digital advertising campaign."
        },
        {
          "info": {
            "name": "Get Campaign",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.tegna.com/v1/campaigns/:campaignId",
            "params": [
              {
                "name": "campaignId",
                "value": "",
                "type": "path"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve details for a specific advertising campaign."
        },
        {
          "info": {
            "name": "Update Campaign",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.tegna.com/v1/campaigns/:campaignId",
            "params": [
              {
                "name": "campaignId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Update an existing advertising campaign."
        }
      ]
    },
    {
      "info": {
        "name": "Reporting",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Campaign Performance",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.tegna.com/v1/campaigns/:campaignId/performance",
            "params": [
              {
                "name": "campaignId",
                "value": "",
                "type": "path"
              },
              {
                "name": "startDate",
                "value": "",
                "type": "query"
              },
              {
                "name": "endDate",
                "value": "",
                "type": "query"
              },
              {
                "name": "granularity",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve performance metrics for a specific campaign."
        }
      ]
    },
    {
      "info": {
        "name": "Markets",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Markets",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.tegna.com/v1/markets",
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve available TEGNA broadcast markets for campaign targeting."
        }
      ]
    }
  ],
  "bundled": true
}